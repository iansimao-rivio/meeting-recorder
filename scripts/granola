#!/bin/bash
# granola - Linux alternative to Granola.ai
# Auto-configures Whisper (local) + Claude Code CLI on first run
# Detaches from the terminal so closing it doesn't kill the app

VENV_DIR="$HOME/.venv/meeting"
CONFIG_DIR="$HOME/.config/meeting-recorder"
CONFIG_FILE="$CONFIG_DIR/config.json"
LOG_DIR="$HOME/.local/share/meeting-recorder"
LOG_FILE="$LOG_DIR/granola.log"

if [ ! -d "$VENV_DIR" ]; then
    echo "Error: venv not found at $VENV_DIR"
    echo "Run: python -m venv $VENV_DIR && source $VENV_DIR/bin/activate && pip install git+https://github.com/AJV009/meeting-recorder.git PyGObject"
    exit 1
fi

if [ ! -f "$CONFIG_FILE" ]; then
    echo "First run: configuring Whisper + Claude Code..."
    mkdir -p "$CONFIG_DIR"
    cat > "$CONFIG_FILE" << 'EOF'
{
  "transcription_provider": "whisper",
  "summarization_provider": "claude_code",
  "whisper_model": "large-v3-turbo",
  "audio_backend": "pipewire",
  "output_folder": "~/meetings",
  "recording_quality": "high",
  "api_keys": {}
}
EOF
    mkdir -p "$HOME/meetings"
fi

mkdir -p "$LOG_DIR"

# Force ASCII system error messages so PyAV/faster-whisper don't trip over
# UTF-8 strerror output on locales like pt_BR.UTF-8.
export LC_MESSAGES=C

# Foreground mode with --fg / -f; default detaches from the terminal
if [ "$1" = "--fg" ] || [ "$1" = "-f" ]; then
    shift
    source "$VENV_DIR/bin/activate"
    exec meeting-recorder "$@"
fi

# Detach: new session, no controlling tty, stdout/stderr to log
setsid nohup bash -c "
    export LC_MESSAGES=C
    source '$VENV_DIR/bin/activate'
    exec meeting-recorder $*
" </dev/null >>"$LOG_FILE" 2>&1 &
disown
echo "granola started (PID $!) — logs: $LOG_FILE"
