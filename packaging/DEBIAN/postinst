#!/bin/bash
set -e

APP_DIR="/opt/meeting-recorder"
VENV_DIR="$APP_DIR/venv"
LOG_DIR="/var/log/meeting-recorder"
APT_REPO="https://dipakmdhrm.github.io/meeting-recorder"
KEYRING="/etc/apt/keyrings/meeting-recorder.gpg"
SOURCES="/etc/apt/sources.list.d/meeting-recorder.list"

# Create Python virtual environment and install dependencies
python3 -m venv "$VENV_DIR" --system-site-packages
"$VENV_DIR/bin/pip" install --quiet --upgrade pip
"$VENV_DIR/bin/pip" install --quiet -r "$APP_DIR/requirements.txt"

# Install Ollama on fresh installs only (not upgrades)
if [ -z "$2" ] && ! command -v ollama >/dev/null 2>&1; then
    curl -fsSL https://ollama.com/install.sh | sh || \
        echo "[warn] Ollama installation failed. Install manually from https://ollama.com if needed."
fi

# Create system log directory, world-writable so any user can write logs
mkdir -p "$LOG_DIR"
chmod 1777 "$LOG_DIR"

# Configure apt repository on fresh installs only (persists across upgrades)
if [ -z "$2" ]; then
    mkdir -p /etc/apt/keyrings
    curl -fsSL "${APT_REPO}/key.gpg" | gpg --dearmor -o "$KEYRING"
    echo "deb [arch=amd64 signed-by=${KEYRING}] ${APT_REPO} stable main" > "$SOURCES"
    apt-get update -qq 2>/dev/null || true
fi

# Update desktop database
update-desktop-database /usr/share/applications 2>/dev/null || true
